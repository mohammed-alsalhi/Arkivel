# ===========================================
# Required
# ===========================================

# PostgreSQL connection string (e.g. Neon, Supabase, or local)
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# Admin password — leave empty to disable auth (local dev)
ADMIN_SECRET=""

# ===========================================
# Arkivel Customization (all optional)
# ===========================================

# Display name shown in header, footer, and metadata
NEXT_PUBLIC_ARKIVEL_NAME="Arkivel"

# Short tagline shown in the top banner bar
NEXT_PUBLIC_ARKIVEL_TAGLINE="The self-hosted knowledge platform"

# Meta description for SEO
NEXT_PUBLIC_ARKIVEL_DESCRIPTION="A powerful open-source knowledge platform for individuals and teams"

# Welcome message on the home page
NEXT_PUBLIC_ARKIVEL_WELCOME_TEXT="Welcome to Arkivel. Create articles, organize knowledge, and build your own encyclopedia — on infrastructure you own."

# Footer text (shown after the site name)
NEXT_PUBLIC_ARKIVEL_FOOTER_TEXT="Content is available under Creative Commons Attribution."

# ===========================================
# Map Feature (optional)
# ===========================================

# Set to "true" to enable the interactive map page
NEXT_PUBLIC_MAP_ENABLED="false"

# Label for the map in navigation and headings
NEXT_PUBLIC_MAP_LABEL="Map"

# Path or URL to the map background image
NEXT_PUBLIC_MAP_IMAGE=""

# ===========================================
# Feature Toggles (optional)
# ===========================================

# Default locale (default: "en")
NEXT_PUBLIC_DEFAULT_LOCALE="en"

# Articles per page on listing pages (default: 20)
NEXT_PUBLIC_ARTICLES_PER_PAGE="20"

# Max upload size in bytes (default: 5242880 = 5MB)
NEXT_PUBLIC_MAX_UPLOAD_SIZE="5242880"

# Set to "false" to disable user registration
NEXT_PUBLIC_ENABLE_REGISTRATION="true"

# Set to "false" to disable article discussions
NEXT_PUBLIC_ENABLE_DISCUSSIONS="true"

# ===========================================
# SEO (optional)
# ===========================================

# Base URL for sitemap, Open Graph, and canonical URLs
NEXT_PUBLIC_BASE_URL="https://example.com"

# ===========================================
# Image Uploads (optional)
# ===========================================

# Vercel Blob token for image uploads
BLOB_READ_WRITE_TOKEN=""
